{
    "name": "bmd/button-block-enhancements",
    "description": "Enable hover/focus colors and icon support to the core/button block",
    "type": "library",
    "license": "GPL-2.0-or-later",
    "minimum-stability": "dev",
    "prefer-stable": true,
    "config": {
        "optimize-autoloader": false,
        "vendor-dir": "vendor",
        "platform": {
            "php": "8.2"
        },
        "allow-plugins": {
            "composer/installers": true,
            "dealerdirect/phpcodesniffer-composer-installer": true,
            "phpstan/extension-installer": true,
            "wpify/scoper": true
        }
    },
    "autoload": {
        "psr-4": {
            "Bmd\\ButtonBlockEnhancements\\": "inc"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Bmd\\ButtonBlockEnhancements\\PHPUnit\\": "tests/phpunit"
        }
    },
    "require": {
        "php-di\/php-di": "^7.1"
    },
    "require-dev": {
        "bmd/github-wp-updater": "^0.1.2",
        "squizlabs/php_codesniffer": "^3.7",
        "phpunit/phpunit": "^9.6",
        "symfony/var-dumper": "*",
        "wp-coding-standards/wpcs": "^3.0",
        "phpstan/phpstan": "^1.10",
        "szepeviktor/phpstan-wordpress": "^1.3",
        "phpcsstandards/phpcsutils": "^1.0",
        "wpify/scoper": "^3.2",
        "10up/wp_mock": "*"
    },
    "scripts": {
        "build-release": "node scripts/build-plugin-release.mjs",
        "phpstan": "./vendor/bin/phpstan analyze -c ./tests/phpstan.neon --memory-limit=2048M",
        "phpsniff": "./vendor/bin/phpcs ./inc -v --standard='./tests/phpcs.xml'",
        "phpsniff:fix": "./vendor/bin/phpcbf ./inc -v --standard='./tests/phpcs.xml'",
        "phpsniff:default": "./vendor/bin/phpcs ./inc -v",
        "phpsniff:PSR12": "./vendor/bin/phpcs ./inc -v --standard='PSR12'",
        "phpsniff:PSR2": "./vendor/bin/phpcs ./inc -v --standard='PSR2'",
        "phpsniff:WP": "./vendor/bin/phpcs ./inc -v --standard='WordPress'",
        "phpunit": "./vendor/bin/phpunit --configuration ./tests/phpunit.xml --verbose",
        "zip": "zip -r button-block-enhancements.zip"
    },
    "extra": {
        "plugin-release": {
            "files": [
                "assets",
                "build",
                "inc",
                "README.md",
                "readme.md",
                "readme.txt",
                "LICENSE",
                "license.txt",
                "button-block-enhancements.php"
            ]
        },
        "wpify-scoper": {
            "prefix": "Bmd\\ButtonBlockEnhancements",
            "slug": "button_block_enhancements",
            "folder": "./vendor/scoped",
            "globals": [
                "wordpress",
                "woocommerce"
            ],
            "autorun": false,
            "source-namespace-patches": [
                "DI\\",
                "Psr\\Container\\"
            ]
        }
    }
}
